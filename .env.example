# Where the funding-data-backend is running.
VITE_API_BASE_URL=http://localhost:4000

# Backend selector. One of:
#   http          (default)  — talks to funding-data-backend on VITE_API_BASE_URL
#   supabase                 — legacy Supabase project (read/write to its tables)
#   legacy-fastapi           — pre-existing FastAPI on http://localhost:8000 (CRA pages only)
VITE_DATA_SOURCE=http
