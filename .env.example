# Where the funding-data-backend is running.
VITE_API_BASE_URL=http://localhost:4000

# Backend selector. One of:
#   http          (default)  — talks to funding-data-backend on VITE_API_BASE_URL
#   supabase                 — legacy Supabase project (read/write to its tables)
#   legacy-fastapi           — pre-existing FastAPI on http://localhost:8000 (CRA pages only)
VITE_DATA_SOURCE=http

# ─── Dev-server (Vite) settings ───────────────────────────────────────────
# These are server-only — they don't ship to the browser, so they have no
# VITE_ prefix. Override at the shell (`FRONTEND_PORT=5180 npm run dev`) or
# in .env.local.
#
# Port for `npm run dev` and `npm run preview`. Default 5174.
FRONTEND_PORT=5174
# Host bind. Default localhost. Set to 0.0.0.0 to expose on the LAN.
FRONTEND_HOST=localhost
# If true, fail fast when FRONTEND_PORT is already taken instead of falling
# through to the next free port. Useful in CI / containerized setups.
FRONTEND_STRICT_PORT=false
